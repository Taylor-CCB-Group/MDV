{
  "name": "mdv",
  "version": "0.0.2",
  "description": "Multi Dimensional Viewer (MDV) is tool for analyzing, annotating  and sharing multi dimensional data.  It is inspired by [dc charts](https://dc-js.github.io/dc.js/) and [crossfilter](https://square.github.io/crossfilter/), but is performant with over 10 million data items due to the use of web workers, shared array buffers and native arrays.   &nbsp; ![summary](images/summary.png)",
  "main": "index.js",
  "type": "module",
  "packageManager": "pnpm@10.21.0",
  "directories": {
    "example": "examples"
  },
  "scripts": {
    "dev": "cross-env build=dev_pt vite --host",
    "vite-build": "tsgo && cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" build=dev_pt vite build --outDir ./vite-dist",
    "build": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" build=desktop vite build --outDir ./dist",
    "build-standalone": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" build=production mdv_version=0.0.1 exclude_dir=true asset_base=/static/mdv/ vite build --outDir ./dist/mdv",
    "build-flask-vite-jbrowse": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" build=desktop_pt worker_format=es vite build --outDir ./python/mdvtools/static",
    "build-flask-vite": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" build=desktop_pt vite build --outDir ./python/mdvtools/static",
    "build-flask-dockerjs": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" build=desktop_pt vite build --outDir ./dist/flask",
    "build-flask-dockerjs-analyze": "cross-env VITE_BUNDLE_ANALYZE=1 pnpm run build-flask-dockerjs && node ./scripts/open-bundle-report.mjs",
    "build-flask-docker-hotfix": "cross-env build=desktop_pt vite build --outDir ./python/dist_hotfix/flask",
    "build-schemas": "cd scripts && node --experimental-strip-types ./generate-schemas.ts",
    "docs-env-setup": "python -m venv docsenv && docsenv/bin/pip install -r docs/requirements.txt && pnpm --prefix . run build-docs-nix",
    "build-docs": "docsenv/bin/python -m sphinx -M html docs/maindocs docs/maindocs/_build",
    "build-docs-nix": "pnpm --prefix . run build-docs",
    "serve-docs": "pnpm dlx http-server docs/maindocs/_build/html",
    "build-jsdocs": "jsdoc -c docs/jsdocs/jsdoc.json",
    "build-tsdocs": "pnpm exec typedoc",
    "python-setup": "cd python && uv sync --group dev --frozen && cd .. && pnpm run build-flask-vite",
    "mdv_desktop": "cd python && uv run -- python -m mdvtools.mdv_desktop",
    "docker_build": "docker compose build && docker compose -f docker-compose-dev.yml up -d --force-recreate",
    "docker_dev": "docker compose -f docker-secrets.yml up -d --force-recreate",
    "docker_purge": "docker rm -f $(docker ps -a -q) && docker rmi -f $(docker images -q) && docker volume rm $(docker volume ls -q)",
    "docker_stack_rm": "docker stack rm mdv_stack",
    "docker_createandpush": "docker build -t my_mdv_app_image:latest . && docker tag my_mdv_app_image:latest mdvadmin/my_mdv_app_image:latest && docker push mdvadmin/my_mdv_app_image:latest",
    "docker_stack_deploy": "docker stack deploy -c docker-compose-stack.yml mdv_stack",
    "docker_prune": "docker system prune -a",
    "docker_stack_prune": "docker stack rm mdv_stack && docker container prune -f && docker image prune -a -f && docker volume prune -f",
    "fix_pnpm_win": "pnpm config set script-shell \"cmd\"",
    "jslint": "biome lint --write ./src",
    "jsformat": "biome format --write ./src",
    "lint:react-compiler": "eslint --config eslint.react-compiler.config.mjs \"src/**/*.{ts,tsx}\"",
    "test": "vitest",
    "playwright-setup": "pnpm install && pnpm exec playwright install --with-deps",
    "playwright-preflight-project": "node scripts/playwright/playwright_project_preflight.mjs",
    "playwright-test": "node scripts/playwright/playwright_all_runner.mjs",
    "playwright-test-catalog": "node scripts/playwright/playwright_catalog_runner.mjs",
    "playwright-test-catalog-ui": "node scripts/playwright/playwright_catalog_runner.mjs --ui",
    "playwright-test-catalog-dev": "node scripts/playwright/playwright_catalog_dev_runner.mjs",
    "playwright-test-catalog-dev-ui": "node scripts/playwright/playwright_catalog_dev_runner.mjs --ui",
    "playwright-test-project": "node scripts/playwright/playwright_project_runner.mjs",
    "playwright-test-project-ui": "node scripts/playwright/playwright_project_runner.mjs --ui",
    "playwright-test-all": "node scripts/playwright/playwright_all_runner.mjs",
    "playwright-test-ui": "node scripts/playwright/playwright_all_runner.mjs --ui"
  },
